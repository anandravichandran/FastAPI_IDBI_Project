# =====================================================================
# Financial Suite — shared environment
# Both sub-apps read the same process environment. Shared keys (DeepSeek,
# logging, RAG) apply to both; app-specific keys are grouped below.
# =====================================================================

# ---- Environment / logging (shared) ----
ENVIRONMENT=local            # local | dev | staging | production
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true

# =====================================================================
# Security & hardening (shared, read by the common.* gateway layer)
# Auth and rate limiting default ON when ENVIRONMENT=production and OFF
# otherwise, so local dev and the test suite run without credentials.
# =====================================================================
# Force-enable/disable authentication regardless of ENVIRONMENT.
# AUTH_ENABLED=true
# Comma-separated allowlist of gateway API keys (X-API-Key header).
API_KEYS=
# Header name clients use to send the API key.
API_KEY_HEADER=X-API-Key
# HS256 (default) JWT bearer verification. Leave JWT_SECRET empty to disable.
JWT_SECRET=
JWT_ALGORITHMS=HS256
# JWT_ISSUER=
# JWT_AUDIENCE=
# Explicit Host allowlist (TrustedHostMiddleware). '*' only for local dev.
TRUSTED_HOSTS=*
# Explicit CORS origins; NEVER combine '*' with credentials.
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
# Edge rate limiting (token bucket per client IP).
# RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=40
# Security response headers + HSTS.
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
# SSRF allowlist for outbound LLM/market calls (host names).
OUTBOUND_ALLOWED_HOSTS=api.deepseek.com,integrate.api.nvidia.com

# ---- LLM provider selection (shared) ----
# "deepseek" (default; talks to api.deepseek.com) or
# "nvidia" (NVIDIA NIM hosted inference, e.g. DeepSeek V4 Pro).
# Used by the /advisor and /coach sub-apps.
LLM_PROVIDER=deepseek

# ---- DeepSeek V3 (shared, OpenAI-compatible) ----
# Leave DEEPSEEK_API_KEY empty to run both apps with the deterministic
# fallback narrator (no network calls).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60

# ---- NVIDIA NIM (shared, OpenAI-compatible) ----
# Set LLM_PROVIDER=nvidia and provide a key to route /advisor and /coach
# completions through NVIDIA's hosted DeepSeek V4 Pro model.
# NEVER commit a real key; keep it in the git-ignored .env file only.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_TIMEOUT_SECONDS=60
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=16384
# Toggle DeepSeek V4's extended "thinking" reasoning mode (true|false).
NVIDIA_THINKING=false

# ---- RAG (shared) ----
RAG_TOP_K=4
# RAG_KNOWLEDGE_PATH=

# ---------------------------------------------------------------------
# Investment Advisor (/advisor)
# ---------------------------------------------------------------------
# APP_NAME defaults to "Investment Advisor Service" for this sub-app.
# DeepSeek tuning used by the advisor:
# DEEPSEEK_TEMPERATURE=0.2
# DEEPSEEK_MAX_TOKENS=1400
# OpenBB market data (optional; stub used if absent):
OPENBB_PAT=
OPENBB_PROVIDER=yfinance
MARKET_DATA_TIMEOUT_SECONDS=20
# Planning defaults:
EMERGENCY_FUND_MONTHS=6

# ---------------------------------------------------------------------
# Financial Coach (/coach)
# ---------------------------------------------------------------------
# APP_NAME defaults to "Financial Coach Service" for this sub-app.
# DeepSeek tuning used by the coach:
# DEEPSEEK_TEMPERATURE=0.3
# DEEPSEEK_MAX_TOKENS=1200
# Conversation history:
HISTORY_MAX_TURNS=50
HISTORY_CONTEXT_TURNS=6
# Coaching rules:
HEALTHY_SAVINGS_RATE_PCT=20
MAX_FOIR_PCT=40
CAR_LOAN_RATE_PCT=9.5
HOME_LOAN_RATE_PCT=8.5
DEFAULT_CAR_LOAN_YEARS=7
DEFAULT_HOME_LOAN_YEARS=20

# ---------------------------------------------------------------------
# Budget Planner (/budget)
# ---------------------------------------------------------------------
# APP_NAME defaults to "Budget Planner Service" for this sub-app.
# 50/30/20 budgeting framework targets (percent of income):
NEEDS_TARGET_PCT=50
WANTS_TARGET_PCT=30
SAVINGS_TARGET_PCT=20
# Alert thresholds:
MIN_SAVINGS_PCT=10
BILL_BURDEN_WARN_PCT=35
OVERSPEND_TOLERANCE_PCT=5
DEFAULT_CURRENCY=INR

# ---------------------------------------------------------------------
# Savings Optimizer (/savings)
# ---------------------------------------------------------------------
# APP_NAME defaults to "Savings Optimizer Service" for this sub-app.
# Planning rules:
EMERGENCY_FUND_MONTHS=6
# HEALTHY_SAVINGS_RATE_PCT / MAX_FOIR_PCT are shared with the coach above.
LONG_HORIZON_MONTHS=60
SHORT_HORIZON_MONTHS=36
# Allocation presets (percent of investable monthly surplus).
# While the emergency fund is still building, bias to liquid:
EF_BUILDING_SIP_PCT=20
EF_BUILDING_FD_PCT=20
EF_BUILDING_LIQUID_PCT=60
# Once fully funded, risk-based growth presets:
MODERATE_SIP_PCT=55
MODERATE_FD_PCT=30
MODERATE_LIQUID_PCT=15

# ---------------------------------------------------------------------
# RAG Service (/rag)
# ---------------------------------------------------------------------
# APP_NAME defaults to "RAG Service" for this sub-app.
# Uploads:
MAX_UPLOAD_MB=25
# Chunking (character-based, boundary-aware):
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MIN_CHUNK_CHARS=60
# Embeddings: "sentence_transformers" (production) | "hashing" (light fallback)
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HASHING_EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32
# Vector store: "chromadb" (production) | "memory" (light fallback)
VECTOR_BACKEND=chromadb
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=documents
# Retrieval:
DEFAULT_TOP_K=5
MAX_TOP_K=20
MIN_RELEVANCE_SCORE=0.0
# Context assembly for DeepSeek:
MAX_CONTEXT_CHARS=6000

# NOTE: APP_NAME is intentionally left unset so each sub-app uses its own
# default title. Setting APP_NAME here would override the title for ALL.
# NOTE: RAG_TOP_K (advisor/coach) and DEFAULT_TOP_K (rag) are distinct keys.

# ---------------------------------------------------------------------
# Market Data Service (/market)
# ---------------------------------------------------------------------
# All keys are prefixed MARKET_ and are read only by the /market sub-app.
# APP_NAME defaults to "OpenBB Market Data Service".
MARKET_ENVIRONMENT=development       # development | staging | production
# Provider backend: "openbb" (production) | "synthetic" (deterministic offline)
MARKET_PROVIDER_BACKEND=openbb
# OpenBB Platform Personal Access Token (optional; anonymous access if unset):
MARKET_OPENBB_PAT=
# Preferred OpenBB data vendor for equities (e.g. yfinance, fmp, intrinio):
MARKET_OPENBB_EQUITY_PROVIDER=yfinance
MARKET_DEFAULT_CURRENCY=USD

# ---- Caching (per-domain TTLs, seconds) ----
MARKET_CACHE_ENABLED=true
MARKET_CACHE_MAX_ENTRIES=2048
MARKET_CACHE_TTL_QUOTE=30
MARKET_CACHE_TTL_HISTORICAL=900
MARKET_CACHE_TTL_RATIOS=3600
MARKET_CACHE_TTL_NEWS=300
MARKET_CACHE_TTL_REFERENCE=86400

# ---- Retries (exponential backoff + jitter) ----
MARKET_RETRY_MAX_ATTEMPTS=3
MARKET_RETRY_BASE_DELAY=0.25
MARKET_RETRY_MAX_DELAY=5.0
MARKET_RETRY_JITTER=0.1

# ---- Rate limiting (client-side token bucket) ----
MARKET_RATE_LIMIT_ENABLED=true
MARKET_RATE_LIMIT_RPM=120
MARKET_RATE_LIMIT_BURST=30
# Seconds to block waiting for a token before returning HTTP 429 (0 = fail fast):
MARKET_RATE_LIMIT_ACQUIRE_TIMEOUT=0.0

# ---- Query defaults / bounds ----
MARKET_DEFAULT_INTERVAL=1d           # 1d | 1w | 1m
MARKET_MAX_HISTORY_POINTS=2000
MARKET_DEFAULT_HISTORY_DAYS=365
MARKET_DEFAULT_NEWS_LIMIT=20
MARKET_MAX_NEWS_LIMIT=100
